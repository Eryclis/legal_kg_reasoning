    <edge source="REsp_1556132" target="EXT_RESP_1453275/SC">
      <data key="d3">CITES_EXTERNAL</data>
      <data key="d4">1.0</data>
      <data key="d17">REsp 1453275/SC</data>
      <data key="d18">tatação que se limita a elencar a mercadoria apreendida. 2. Recurso provido. (REsp 1453275/SC, da minha relatoria, SEXTA TURMA, julgado em 15/09/2015, DJe 01/10/2015) RECUR</data>
      <data key="d19">bare_mention</data>
